modules = ["nodejs-24", "postgresql-16"]

[[artifacts]]
id = "artifacts/api-server"

[[artifacts]]
id = "artifacts/mockup-sandbox"

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "artifacts/finca-desktop: TypeScript (watch)"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-finca-desktop"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "test-finca-web"

[[workflows.workflow]]
name = "artifacts/finca-desktop: TypeScript (watch)"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/finca-desktop exec tsc --watch --noEmit false"

[workflows.workflow.metadata]
outputType = "console"

[[workflows.workflow]]
name = "test-finca-desktop"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/finca-desktop test"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "test-finca-web"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "pnpm --filter @workspace/finca-web test"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
